#!/bin/sh
selected=$( (echo -e "NETWORK/WIFI\nWEB\nEDITOR\nSOUND/AUDIO\nFILES"; dmenu_path) | dmenu "$@" | tr '[:upper:]' '[:lower:]' )
case $selected in
    network/wifi|nmtui) st -e nmtui & ;;
    web) google-chrome-stable --no-sandbox --force-dark-mode --force-device-scale-factor=1.5 & ;;
    editor) st -e vim & ;;
    sound/audio) st -e alsamixer & ;;
    files) st -e mc & ;;
    *) [ -n "$selected" ] && $selected & ;;
esac
