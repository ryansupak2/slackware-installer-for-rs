#!/bin/bash
shopt -s expand_aliases
source ~/.bashrc
selected=$( (echo -e "WEB\nEDITOR\nFILES\nNETWORK/WIFI\nSOUND/AUDIO\nVPN"; bash -c 'source ~/.bashrc && alias' | cut -d'=' -f1 | sed 's/alias //' ; dmenu_path) | dmenu "$@" | tr '[:upper:]' '[:lower:]' )
case $selected in
    web) chrome & ;;
    editor) st -e vim & ;;
    files) st -e mc & ;;
    network/wifi|nmtui) st -e nmtui & ;;
    sound/audio) st -e alsamixer & ;;
    vpn) st -e sh -c nordvpn-run.sh & ;;
    *) [ -n "$selected" ] && bash -c "shopt -s expand_aliases; source ~/.bashrc; $selected" & ;;
esac
