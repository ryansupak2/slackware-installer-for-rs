#!/bin/sh
selected=$( (echo -e "wifi\nweb\neditor\nnetwork"; dmenu_path) | dmenu "$@" | tr '[:upper:]' '[:lower:]' )
case $selected in
    wifi|network|nmtui) st -e nmtui & ;;
    web) google-chrome-stable --no-sandbox & ;;
    editor) st -e vim & ;;
    *) [ -n "$selected" ] && $selected & ;;
esac
