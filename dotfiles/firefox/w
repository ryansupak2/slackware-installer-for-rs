#!/bin/sh
uri="about:blank"
if [ $# -gt 0 ]; then
    raw="$1"
    case "$raw" in
        *://*) uri="$raw" ;;
        *)
            f="${HOME}/.surf/shortcuts"
            [ -f "$f" ] || f="/etc/surf/shortcuts.default"
            if [ -f "$f" ]; then
                resolved=$(awk -v key="$raw" '$1 == key {print $2; exit}' "$f")
                [ -n "$resolved" ] && uri="$resolved"
            fi
            # fallback: treat unrecognized input as a raw URL
            [ "$uri" = "about:blank" ] && uri="$raw"
            ;;
    esac
fi
exec firefox "$uri"
