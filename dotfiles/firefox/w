#!/bin/sh
uri="about:blank"
if [ $# -gt 0 ]; then
    raw="$1"
    case "$raw" in
        *://*) uri="$raw" ;;
        *)
            f="${HOME}/.web/shortcuts"
            [ -f "$f" ] || f="${HOME}/.surf/shortcuts"
            [ -f "$f" ] || f="/etc/web/shortcuts.default"
            [ -f "$f" ] || f="/etc/surf/shortcuts.default"
            if [ -f "$f" ]; then
                resolved=$(awk -v key="$raw" '$1 == key {print $2; exit}' "$f")
                [ -n "$resolved" ] && uri="$resolved"
            fi
            # If no shortcut matched and input looks like a domain/URL, add https://
            if [ "$uri" = "about:blank" ]; then
                case "$raw" in
                    *.*) uri="https://$raw" ;;
                esac
            fi
            ;;
    esac
fi
exec firefox "$uri"
