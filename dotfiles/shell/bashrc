# Keyboard backlight: no longer set automatically on shell start.
# (Set once at X session start by ~/.xinitrc to 50%.)

# console prompt (restored): LoggedInUser@TopDirectory in shades of green/blue
# (matches pre-refactor behavior; overrides system /etc/profile PS1)
export PS1='\[\e[32m\]\u@\[\e[38;5;153m\]\W\[\e[0m\]\$ '

# to make draw (inkscape) font a readable size
export GDK_DPI_SCALE=1.5

# Node.js + pi runtime (matches pi installer location)
export PATH=/usr/local/node-v22.19.0-linux-x64/bin:$PATH
# screen locking: 'lock' works in dwl (wlock) and on TTY (physlock)
alias lock='/usr/local/bin/lock-screen.sh'  #help:lock=lock screen (wlock in dwl, physlock on TTY)

