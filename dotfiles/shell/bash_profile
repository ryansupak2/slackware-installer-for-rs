# .bash_profile - sourced for login shells (bash -l, login sessions, etc.)

# Source .bashrc for aliases, PS1, PATH, etc.
# This ensures aliases (gs, vi, help, wifi, etc.) work even in login shells.
if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
fi

# Optional: any login-only setup can go below (e.g. ssh-agent, keychain already appended to .bashrc by the installer)

# LOG_DIR and LOG are set by .bashrc (sourced above); fall back if not set
LOG="${LOG:-$HOME/logs/${USER:-root}-shell-init.log}"

# Login-only: bare TTY console → flush stale VPN + neofetch
# (DWL_FIRST_TERMINAL and hide_mode newline are handled by .bashrc)
case "$(tty 2>/dev/null)" in
    /dev/tty*)
        echo "[$(date '+%H:%M:%S')] tty-login: flushing VPN + neofetch" >> "$LOG"
        sudo /usr/bin/pkill openvpn 2>/dev/null || true
        neofetch
        ;;
esac
